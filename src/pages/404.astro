---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page not found · STT Index"
  description="This page isn't in the index. Browse the library of speech-to-text models instead."
>
  <div class="notfound">
    <div class="notfound-code">ERROR 404 — NOT IN THE INDEX</div>
    <h1 class="notfound-title">This page doesn't exist.</h1>
    <p class="notfound-sub">
      The entry you're looking for may have moved, or the address was mistyped. Everything we've
      catalogued lives in the library.
    </p>
    <div class="hero-ctas">
      <a href="/library/" class="btn-primary">Browse the library →</a>
      <a href="/" class="btn-secondary">Back to home</a>
    </div>
  </div>
</Base>
