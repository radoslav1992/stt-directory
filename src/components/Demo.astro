---
import type { ModelEntry } from '../data/models';

interface Props {
  model: ModelEntry;
}

const { model } = Astro.props;
const demo = model.demo!;
---

<div class="demo" data-demo>
  <div class="demo-head">
    <h2 class="demo-title">Run it in your browser</h2>
    <span class="demo-live">● LIVE — 100% LOCAL</span>
  </div>
  <p class="demo-note">
    {demo.note} Your audio is processed on your device and never uploaded anywhere.
  </p>
  <div class="demo-controls">
    <select class="demo-select" data-model-select aria-label="Choose a checkpoint to load">
      {
        demo.models.map((m) => (
          <option
            value={m.hfId}
            data-webgpu-only={m.webgpuOnly ? 'true' : 'false'}
            data-dtype={m.dtype ?? ''}
            data-label={m.label}
          >
            {m.label} — {m.size}
            {m.webgpuOnly ? ' · WebGPU' : ''}
          </option>
        ))
      }
    </select>
    <button class="demo-btn" data-load>Load model</button>
    <button class="demo-btn" data-record hidden>● Record from mic</button>
    <label class="demo-upload" hidden>
      Upload an audio file
      <input type="file" accept="audio/*" data-file />
    </label>
    <span class="demo-status" data-status aria-live="polite"></span>
  </div>
  <blockquote class="demo-result" data-result hidden></blockquote>
</div>

<script>
  const TRANSFORMERS_CDN =
    'https://cdn.jsdelivr.net/npm/@huggingface/transformers@3.3.3/dist/transformers.min.js';

  const root = document.querySelector<HTMLElement>('[data-demo]');

  if (root) {
    const select = root.querySelector<HTMLSelectElement>('[data-model-select]')!;
    const loadBtn = root.querySelector<HTMLButtonElement>('[data-load]')!;
    const recordBtn = root.querySelector<HTMLButtonElement>('[data-record]')!;
    const uploadLabel = root.querySelector<HTMLLabelElement>('.demo-upload')!;
    const fileInput = root.querySelector<HTMLInputElement>('[data-file]')!;
    const statusEl = root.querySelector<HTMLElement>('[data-status]')!;
    const resultEl = root.querySelector<HTMLElement>('[data-result]')!;

    let asr: any = null;
    let loadedModelId: string | null = null;
    let recorder: MediaRecorder | null = null;
    let recording = false;

    const hasWebGPU = 'gpu' in navigator;

    const setStatus = (msg: string) => {
      statusEl.textContent = msg;
    };

    // Checkpoints marked WebGPU-only are unusable on WASM-only browsers.
    if (!hasWebGPU) {
      for (const opt of Array.from(select.options)) {
        if (opt.dataset.webgpuOnly === 'true') {
          opt.disabled = true;
          opt.textContent += ' (needs WebGPU — not available in this browser)';
        }
      }
      if (select.selectedOptions[0]?.disabled) {
        const firstEnabled = Array.from(select.options).find((o) => !o.disabled);
        if (firstEnabled) select.value = firstEnabled.value;
      }
    }

    // Switching checkpoints after a load brings the Load button back.
    select.addEventListener('change', () => {
      const changed = select.value !== loadedModelId;
      loadBtn.hidden = !changed && loadedModelId != null;
      recordBtn.hidden = changed;
      uploadLabel.hidden = changed;
      if (changed) setStatus('');
    });

    loadBtn.addEventListener('click', async () => {
      const opt = select.selectedOptions[0];
      const modelId = select.value;
      const label = opt?.dataset.label ?? modelId;
      const dtype = opt?.dataset.dtype || undefined;
      loadBtn.disabled = true;
      select.disabled = true;
      setStatus('loading runtime…');
      try {
        const tf: any = await import(/* @vite-ignore */ TRANSFORMERS_CDN);
        const progress_callback = (p: any) => {
          if (p.status === 'progress' && p.file) {
            setStatus(`downloading ${p.file.split('/').pop()} — ${Math.round(p.progress || 0)}%`);
          }
        };
        const base = { progress_callback, ...(dtype ? { dtype } : {}) };
        if (hasWebGPU) {
          try {
            asr = await tf.pipeline('automatic-speech-recognition', modelId, {
              ...base,
              device: 'webgpu',
            });
          } catch {
            asr = await tf.pipeline('automatic-speech-recognition', modelId, base);
          }
        } else {
          asr = await tf.pipeline('automatic-speech-recognition', modelId, base);
        }
        loadedModelId = modelId;
        loadBtn.hidden = true;
        recordBtn.hidden = false;
        uploadLabel.hidden = false;
        setStatus(`${label} loaded — record or upload audio`);
      } catch (err: any) {
        setStatus('could not load model: ' + ((err && err.message) || err));
      } finally {
        loadBtn.disabled = false;
        select.disabled = false;
      }
    });

    recordBtn.addEventListener('click', async () => {
      if (recording) {
        try {
          recorder?.stop();
        } catch {}
        return;
      }
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        const rec = new MediaRecorder(stream);
        const chunks: Blob[] = [];
        rec.ondataavailable = (e) => chunks.push(e.data);
        rec.onstop = () => {
          stream.getTracks().forEach((t) => t.stop());
          recording = false;
          recordBtn.textContent = '● Record from mic';
          recordBtn.classList.remove('recording');
          transcribeBlob(new Blob(chunks, { type: rec.mimeType }));
        };
        recorder = rec;
        rec.start();
        recording = true;
        recordBtn.textContent = '■ Stop recording';
        recordBtn.classList.add('recording');
        setStatus('recording — press stop when done');
      } catch (err: any) {
        setStatus('microphone unavailable: ' + ((err && err.message) || err));
      }
    });

    fileInput.addEventListener('change', () => {
      const f = fileInput.files && fileInput.files[0];
      if (f) transcribeBlob(f);
      fileInput.value = '';
    });

    async function transcribeBlob(blob: Blob) {
      if (!asr) return;
      setStatus('transcribing locally…');
      resultEl.hidden = true;
      resultEl.textContent = '';
      try {
        const buf = await blob.arrayBuffer();
        const Ctx = window.AudioContext || (window as any).webkitAudioContext;
        const ctx = new Ctx({ sampleRate: 16000 });
        const audio = await ctx.decodeAudioData(buf);
        let data = audio.getChannelData(0);
        if (audio.numberOfChannels > 1) {
          const b = audio.getChannelData(1);
          const mix = new Float32Array(data.length);
          for (let i = 0; i < data.length; i++) mix[i] = (data[i] + b[i]) / 2;
          data = mix;
        }
        ctx.close();
        const out = await asr(data, { chunk_length_s: 30 });
        const text = ((out && out.text) || '').trim();
        resultEl.textContent = '“' + (text || '(no speech detected)') + '”';
        resultEl.hidden = false;
        setStatus('done — transcribed on your device');
      } catch (err: any) {
        setStatus('error: ' + ((err && err.message) || err));
      }
    }
  }
</script>
